{
  "name": "@paket/employee-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mitarbeiter-App",
  "scripts": {
    "dev": "vite --port 5175",
    "build": "pnpm --filter \"@paket/employee-pwa^...\" build && vite build",
    "preview": "vite preview --port 5175",
    "start:prod": "node scripts/write-runtime-env.mjs && vite preview --port 5175",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@paket/api-client": "workspace:*",
    "@paket/domain-types": "workspace:*",
    "@paket/test-fixtures": "workspace:*",
    "@paket/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "jose": "^5.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.3",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@testcontainers/postgresql": "^10.13.2",
    "@testing-library/react": "^16.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "bcrypt": "^6.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
