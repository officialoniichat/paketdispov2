# Employee PWA – local environment. Copy to .env (gitignored) and fill in.
#
# Backend mode: when VITE_API_BASE_URL is set, the app loads the engine-assigned
# bundle from the backend (GET /api/me/today) instead of the offline-demo seed.
# Leave it unset to run the no-backend demo.
VITE_API_BASE_URL=http://localhost:3000

# URL of the Teamlead cockpit for the in-app "Zur Teamlead-App" switch link in
# the header. Defaults to the local dev port (apps/teamlead-web: `vite --port 5174`);
# in production point it at the deployed cockpit URL.
VITE_TEAMLEAD_APP_URL=http://localhost:5174

# Long-lived dev EMPLOYEE bearer token (RS256), minted with the backend's
# AUTH_DEV_PRIVATE_KEY. Decoded payload (the backend verifies the signature):
#   { employee_no: 'ma-101', realm_access: { roles: ['employee'] },
#     name: 'Mitarbeiter 101' }, subject 'dev:ma-101', expiry 30d.
#
# Mint with `jose` (run from apps/backend-api where jose + .env live), e.g.:
#   node --input-type=module -e "import {SignJWT,importPKCS8} from 'jose';\
#   import 'dotenv/config';\
#   const k=await importPKCS8(process.env.AUTH_DEV_PRIVATE_KEY,'RS256');\
#   console.log(await new SignJWT({employee_no:'ma-101',\
#   realm_access:{roles:['employee']},name:'Mitarbeiter 101'})\
#   .setProtectedHeader({alg:'RS256'}).setSubject('dev:ma-101')\
#   .setIssuedAt().setExpirationTime('30d').sign(k))"
VITE_DEV_TOKEN=<paste-minted-rs256-jwt-here>
