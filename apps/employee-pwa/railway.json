{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @paket/employee-pwa build",
    "watchPatterns": [
      "apps/employee-pwa/**",
      "packages/api-client/**",
      "packages/domain-types/**",
      "packages/test-fixtures/**",
      "packages/ui/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @paket/employee-pwa start:prod"
  }
}
