  "info": {
    "title": "Paketlagerdispo Backend API",
    "description": "Digitale Belegverteilung – modular monolith backbone. Status state machine (§7), RBAC (§5/§16.1), audit event log (§7.2), and the case pool/lifecycle (§14.2).",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "me",
      "description": "Employee self-service (own packages only, §16.1)"
    },
    {
      "name": "cases",
      "description": "Employee package-handling lifecycle"
    },
    {
      "name": "teamlead",
      "description": "Teamlead pool steering & issue resolution"
    },
    {
      "name": "live",
      "description": "SSE live status streams"
    },
    {
      "name": "health",
      "description": "Liveness & readiness probes"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "OIDC access token"
      }
    },
    "schemas": {
      "RouteStopDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "sequence": {
            "type": "number"
          },
          "locationCode": {
            "type": "string"
          },
          "scanRequired": {
            "type": "boolean"
          },
          "scanned": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "sequence",
          "locationCode",
          "scanRequired",
          "scanned"
        ]
      },
      "CurrentBundleDto": {
        "type": "object",
        "properties": {
          "bundleId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "plannedEffortMinutes": {
            "type": "number"
          },
          "caseCount": {
            "type": "number"
          },
          "routeStops": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RouteStopDto"
            }
          }
        },
        "required": [
          "bundleId",
          "status",
          "plannedEffortMinutes",
          "caseCount",
          "routeStops"
        ]
      },
      "CaseSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "weBelegNo": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "Anhang A CaseStatus"
          },
          "section": {
            "type": "object",
            "nullable": true,
            "description": "Section 1|2|3|4|7|8, null for prio-only"
          },
          "priorityFlags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "totalQuantity": {
            "type": "number"
          },
          "estimatedMinutes": {
            "type": "number"
          },
          "storageLocationCode": {
            "type": "string"
          },
          "bookingDate": {
            "type": "string",
            "description": "ISO date YYYY-MM-DD"
          }
        },
        "required": [
          "id",
          "weBelegNo",
          "status",
          "priorityFlags",
          "totalQuantity",
          "estimatedMinutes",
          "storageLocationCode",
          "bookingDate"
        ]
      },
      "TodayResponseDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "ISO date YYYY-MM-DD"
          },
          "bundle": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/CurrentBundleDto"
              }
            ]
          },
          "cases": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CaseSummaryDto"
            }
          }
        },
        "required": [
          "date",
          "cases"
        ]
      },
      "TransitionResultDto": {
        "type": "object",
        "properties": {
          "caseId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "version": {
            "type": "number"
          },
          "eventId": {
            "type": "object",
            "nullable": true,
            "description": "Audit event id, if a milestone was recorded"
          }
        },
        "required": [
          "caseId",
          "status",
          "version"
        ]
      },
      "PartialCompleteDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          },
          "completedQuantity": {
            "type": "number"
          }
        }
      },
      "CreateIssueDto": {
        "type": "object",
        "properties": {
          "caseId": {
            "type": "string",
            "description": "Case the issue is reported against"
          },
          "scope": {
            "type": "string",
            "description": "IssueScope: case|position|sku_line|transport_box"
          },
          "issueType": {
            "type": "string",
            "description": "IssueType (Anhang A)"
          },
          "scopeId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "photoKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "caseId",
          "scope",
          "issueType"
        ]
      },
      "DashboardDto": {
        "type": "object",
        "properties": {
          "countsByStatus": {
            "type": "object",
            "description": "Open case count grouped by status"
          },
          "poolSize": {
            "type": "number"
          },
          "prioOpen": {
            "type": "number"
          },
          "oldestOpenBookingDate": {
            "type": "object",
            "nullable": true,
            "description": "Booking date of oldest open case"
          }
        },
        "required": [
          "countsByStatus",
          "poolSize",
          "prioOpen"
        ]
      },
      "PoolItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "weBelegNo": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "Anhang A CaseStatus"
          },
          "section": {
            "type": "object",
            "nullable": true,
            "description": "Section 1|2|3|4|7|8, null for prio-only"
          },
          "priorityFlags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "totalQuantity": {
            "type": "number"
          },
          "estimatedMinutes": {
            "type": "number"
          },
          "storageLocationCode": {
            "type": "string"
          },
          "bookingDate": {
            "type": "string",
            "description": "ISO date YYYY-MM-DD"
          },
          "assignedEmployeeNo": {
            "type": "object",
            "nullable": true
          },
          "effortPoints": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "weBelegNo",
          "status",
          "priorityFlags",
          "totalQuantity",
          "estimatedMinutes",
          "storageLocationCode",
          "bookingDate",
          "effortPoints"
        ]
      },
      "PoolListDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PoolItemDto"
            }
          },
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "limit": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "total",
          "page",
          "limit"
        ]
      },
      "PrioritizeDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "description": "Reason for manual teamlead priority"
          }
        }
      },
      "ParkDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      },
      "ResolveIssueDto": {
        "type": "object",
        "properties": {
          "resolution": {
            "type": "string"
          }
        }
      },
      "ReleaseDto": {
        "type": "object",
        "properties": {
          "note": {
            "type": "string"
          }
        }
      },
      "RecalculateDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Planning date (YYYY-MM-DD). Defaults to today.",
            "example": "2026-06-15"
          }
        }
      },
      "EmployeeLoadDto": {
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "string"
          },
          "capacityMinutes": {
            "type": "number"
          },
          "assignedMinutes": {
            "type": "number"
          },
          "assignedPoints": {
            "type": "number"
          },
          "bundleCount": {
            "type": "number"
          }
        },
        "required": [
          "employeeId",
          "capacityMinutes",
          "assignedMinutes",
          "assignedPoints",
          "bundleCount"
        ]
      },
      "RecalculateResultDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "bundleCount": {
            "type": "number"
          },
          "assignedCaseCount": {
            "type": "number"
          },
          "unassignedCaseCount": {
            "type": "number"
          },
          "reserveMinutes": {
            "type": "number"
          },
          "durationMs": {
            "type": "number",
            "description": "Wall-clock of the engine run (Anhang E.5 budget < 5000ms)."
          },
          "loads": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmployeeLoadDto"
            }
          }
        },
        "required": [
          "date",
          "bundleCount",
          "assignedCaseCount",
          "unassignedCaseCount",
          "reserveMinutes",
          "durationMs",
          "loads"
        ]
      }
    }
  }
}
