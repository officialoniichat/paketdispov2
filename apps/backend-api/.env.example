# ----------------------------------------------------------------------------
# @paket/backend-api – environment template. Copy to .env and adjust per env.
# (The repo-root .env.example covers shared infra; this file is backend-only.)
# ----------------------------------------------------------------------------

# --- Server ---
API_HOST=0.0.0.0
# Local listen port. NOTE: on Railway (and most PaaS) the platform injects PORT,
# which takes precedence over API_PORT — do not hardcode PORT there, let Railway set it.
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Database (Prisma) ---
DATABASE_URL=postgresql://paket:paket_dev_pw@localhost:5432/paketlager?schema=public

# --- CORS ---
# Comma-separated list of allowed origins for the browser frontends.
# Leave empty in local dev (the dev origins http://localhost:5174 and :5175 are used
# automatically). In production set this to the deployed web app URLs to enable
# cross-origin access, e.g.:
# CORS_ORIGINS=https://teamlead.example.com,https://employee.example.com
CORS_ORIGINS=

# --- Auth (OIDC / OAuth2) ---
# In production point these at your IdP (Keycloak / Entra). Left blank, the API runs
# in dev/CI mode and can verify locally-issued tokens via AUTH_DEV_PUBLIC_KEY.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URI=
# Comma-separated claim paths to read roles from (default: realm_access.roles,roles,groups).
OIDC_ROLE_CLAIM_PATHS=
OIDC_EMPLOYEE_NO_CLAIM=employee_no
# Dev/CI only: PEM-encoded RS256 public key to verify locally-issued tokens.
AUTH_DEV_PUBLIC_KEY=

# --- OpenAPI / Swagger ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=backend-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Set to "false" to actually export; default on so local dev runs without a collector.
OTEL_SDK_DISABLED=true
