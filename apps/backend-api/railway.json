{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @paket/backend-api build"
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @paket/backend-api exec prisma migrate deploy",
    "startCommand": "pnpm --filter @paket/backend-api start"
  }
}
