{
  "name": "@paket/teamlead-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Teamlead/Admin Dashboard – Operatives Cockpit & Konfiguration (§10/§11)",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "pnpm --filter \"@paket/teamlead-web^...\" build && vite build",
    "preview": "vite preview --port 5174",
    "start:prod": "node scripts/write-runtime-env.mjs && vite preview --port 5174",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@paket/api-client": "workspace:*",
    "@paket/domain-types": "workspace:*",
    "@paket/test-fixtures": "workspace:*",
    "@paket/ui": "workspace:*",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/react-virtual": "^3.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
