# Teamlead cockpit configuration.
# - Local dev: read by Vite -> import.meta.env (see src/config/runtimeEnv.ts). Copy this
#   file to .env (gitignored) and fill in.
# - Railway/prod: set the SAME variable names as service variables. They are injected at
#   RUNTIME into /env.js (scripts/write-runtime-env.mjs) and read via window.__ENV__, so
#   URLs change WITHOUT a rebuild. Build-time values are still honoured if present.
# Dates passed to the backend use YYYY-MM-DD.

# Backend base URL (NestJS + Fastify API).
VITE_API_BASE_URL=http://localhost:3000

# URL of the Mitarbeiter-App (employee PWA) for the in-app "Zur Mitarbeiter-App"
# switch link in the cockpit header. Defaults to the local dev port
# (apps/employee-pwa: `vite --port 5175`); in production point it at the deployed PWA URL.
VITE_EMPLOYEE_APP_URL=http://localhost:5175

# Long-lived dev teamlead bearer token (RS256). Leave empty in committed files.
# Mint one by signing with apps/backend-api/.env AUTH_DEV_PRIVATE_KEY using `jose`:
#   import { importPKCS8, SignJWT } from 'jose';
#   const key = await importPKCS8(AUTH_DEV_PRIVATE_KEY, 'RS256');
#   const jwt = await new SignJWT({ employee_no: 'tl-001', realm_access: { roles: ['teamlead'] }, name: 'Teamlead' })
#     .setProtectedHeader({ alg: 'RS256' }).setSubject('dev:tl-001').setIssuedAt().setExpirationTime('30d').sign(key);
VITE_DEV_TOKEN=
