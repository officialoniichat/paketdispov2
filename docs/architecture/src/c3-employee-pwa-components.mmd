%% C4 Level 3 — Components: employee-pwa (React + Vite PWA)
%% Verified against apps/employee-pwa/src/* (screens/, workflow/, data/, routes/) — tasks 13-17.
%% Real employee login (data/auth.ts) gates the app; the backend is the single source of
%% truth via React Query plus an SSE live-update channel — the former Dexie-backed db/
%% (offline-first cache), events/ (local audit log) and seed/sync/repository modules are
%% gone (tasks 10-13). Task 15 added useLiveUpdates() (GET /api/me/stream, SSE).
flowchart TB
    classDef screen fill:#16314a,stroke:#56b6ff,color:#eef1f6;
    classDef hook fill:#143a35,stroke:#2dd4a7,color:#eef1f6;
    classDef logic fill:#1d222c,stroke:#8b7cf6,color:#eef1f6;
    classDef ext fill:#23272f,stroke:#7c8696,color:#cbd2dd;

    api["backend-api<br/>/api/auth/login · /api/me/today · /aggregate · next-bundle · park<br/>/api/cases/:id/* · /api/issues · /static/pictograms/* · SSE /api/me/stream"]:::ext

    subgraph pwa["employee-pwa container"]
        direction TB
        subgraph screens["screens/ + components/ (router: routes/paths.ts, App gated by session)"]
            login["LoginScreen<br/><i>nur Mitarbeiternummer (kein PIN) → POST /api/auth/login</i>"]:::screen
            home["BundleHomeScreen<br/><i>/ — Ware holen + Bearbeiten; Problemfall rot geparkt / grün geklärt</i>"]:::screen
            process["BelegProcessScreen<br/><i>/case/:id — sticky Positions-Tabelle, CatMan/Shop/Order, VK korrigiert</i>"]:::screen
            problemDlg["ProblemDialog<br/><i>Problem je Position/Größe (Katalog-Grund, lokal gesammelt)</i>"]:::screen
            teilDlg["TeilabschlussDialog<br/><i>Zusammenfassung aller Probleme → an Teamleitung</i>"]:::screen
        end
        subgraph wf["workflow/ (pure logic + the one live-data hook)"]
            useCaseFlow["useCaseFlow()<br/><i>togglePositionChecked · setSkuQuantity · setCorrectedVkPrice · addProblem/removeProblem · complete · partialComplete</i>"]:::hook
            model["workflowModel.ts<br/><i>guards: canCompleteCase (Problem sperrt) · hasAnyProblem · skuQuantitiesBody · problemsBody</i>"]:::logic
            collectLogic["collect.ts · belegList.ts"]:::logic
        end
        subgraph data["data/ (React Query — backend is the single source of truth)"]
            apiClient["api.ts → @paket/api-client<br/><i>getApiClient() — fresh client per call, current session token</i>"]:::logic
            auth["auth.ts · session.ts<br/><i>login()/logout() · JWT claims · onSessionCleared()</i>"]:::logic
            meToday["useMeToday() · useNextBundle() · useParkRemaining()<br/><i>GET/POST /api/me/* — queryKey ['me','today']</i>"]:::hook
            caseAgg["useCaseAggregate()<br/><i>GET /api/me/cases/:id/aggregate — queryKey ['me','case',id,'aggregate']</i>"]:::hook
            reasons["useProblemReasons()<br/><i>GET /api/problem-reasons — dynamischer Problemarten-Katalog</i>"]:::hook
            mapper["caseAggregateMapper.ts<br/><i>CaseAggregateDto → CaseAggregate (domain/types.ts)</i>"]:::logic
            persist["persist.ts<br/><i>persistStartPreparation/Complete/PartialComplete — plain POST, throws on failure</i>"]:::logic
            focus["useFocusRefresh.ts<br/><i>invalidateQueries(['me','today']) on window focus</i>"]:::hook
            live["useLiveUpdates.ts<br/><i>EventSource /api/me/stream?token= — on message: invalidateQueries(['me','today'])</i>"]:::hook
        end
    end

