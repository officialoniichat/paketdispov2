            login["LoginScreen<br/><i>nur Mitarbeiternummer (kein PIN) → POST /api/auth/login</i>"]:::screen
            home["BundleHomeScreen<br/><i>/ — Ware holen inline + Bearbeiten (frei wählbar) + Rest parken + weiteres Bündel anfordern</i>"]:::screen
