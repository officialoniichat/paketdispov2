%% Welche Daten kommen rein? Beleg-Kopf vs. Position vs. SKU (ASN/DESADV)
flowchart TB
    classDef kopf fill:#16314a,stroke:#56b6ff,color:#eef1f6;
    classDef pos fill:#1d222c,stroke:#8b7cf6,color:#eef1f6;
    classDef sku fill:#143a35,stroke:#2dd4a7,color:#eef1f6;
    classDef aw fill:#3a2b2b,stroke:#f5b955,color:#eef1f6;

    kopf["BELEG-KOPF (1 Wareneingang)<br/>WE-Beleg-Nr · Lieferschein-Nr · Filiale<br/>Abschnitt (1–4,7,8) · Warenart · Lagerplatz<br/>Buchungsdatum · Verladetag · Prio-Kennzeichen"]:::kopf
    pos["POSITION (Artikel-Zeile)<br/>Warengruppe (WGR) · Lieferanten-Artikel-Nr<br/>Farbe · Saison · NOS-Kennzeichen · Shop/Etage"]:::pos
    sku["SKU-ZEILE (EAN × Größe)<br/>EAN · Größe · Soll-Menge<br/>(Ist-Menge wird beim Bearbeiten erfasst)"]:::sku
    awk["ARBEITSANWEISUNG (Kopf)<br/>Preis-Etikett? · Prüf-Modus · Sicherung?<br/>Online? · ZST nötig?"]:::aw
    awp["ARBEITSANWEISUNG (Position)<br/>Etikett anbringen (Ort) · Sicherung (Ort)<br/>Online-Handling · Rotpreis"]:::aw

    kopf -->|"1 : N"| pos
    pos -->|"1 : N"| sku
    kopf -. "1 : 1" .-> awk
    pos -. "1 : 1" .-> awp
