# ----------------------------------------------------------------------------
# Paketlagerdispo – environment template. Copy to .env and adjust for local dev.
# ----------------------------------------------------------------------------

# --- Postgres ---
POSTGRES_USER=paket
POSTGRES_PASSWORD=paket_dev_pw
POSTGRES_DB=paketlager
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Used by Prisma (inside docker network the host is "postgres")
DATABASE_URL=postgresql://paket:paket_dev_pw@localhost:5432/paketlager?schema=public

# --- Redis (BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible object store) ---
MINIO_ROOT_USER=paketminio
MINIO_ROOT_PASSWORD=paketminio_dev_pw
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# --- Backend API ---
API_HOST=0.0.0.0
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=backend-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp
# Set to "true" to actually export; default off so local dev runs without a collector.
OTEL_SDK_DISABLED=true
